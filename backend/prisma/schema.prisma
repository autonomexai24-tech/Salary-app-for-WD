generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String     @id @default(uuid()) @db.Uuid
  name       String     @unique @db.VarChar(100)
  is_deleted Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  employees  Employee[]

  @@index([name])
  @@map("departments")
}

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  firstName       String    @db.VarChar(100)
  lastName        String    @db.VarChar(100)
  phone           String    @db.VarChar(20)
  address         String?   @db.Text
  dateOfBirth     DateTime?
  gender          String?   @db.VarChar(20)
  qualification   String?   @db.VarChar(100)
  salary          Float
  previousSalary  Float?
  permittedLeaves Int?
  is_deleted      Boolean   @default(false)

  departmentId    String    @db.Uuid
  department      Department @relation(fields: [departmentId], references: [id])
  salaries        Salary[]
  payslips        Payslip[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([departmentId])
  @@map("employees")
}

model Salary {
  id              String   @id @default(uuid()) @db.Uuid
  
  employeeId      String   @db.Uuid
  employee        Employee @relation(fields: [employeeId], references: [id])

  month           Int
  year            Int

  workingDays     Int
  workingHours    Int

  basicSalary     Float
  incentive       Float?
  bonus           Float?
  taDa            Float?
  arrears         Float?

  otHours         Float?
  otPay           Float?

  leavesTaken     Int?
  leavePenalty    Float?

  minusMinutes    Int?
  timePenalty     Float?

  extraFine       Float?

  professionalTax Float?
  emi             Float?

  advanceTaken    Float?
  advanceDeducted Float?

  grossSalary     Float
  totalDeduction  Float
  netSalary       Float

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payslip         Payslip?

  // Strictly enforce one salary entry per employee / per month / per year context limit.
  @@unique([employeeId, month, year])
  @@map("salaries")
}

model Payslip {
  id              String   @id @default(uuid()) @db.Uuid
  
  employeeId      String   @db.Uuid
  salaryId        String   @unique @db.Uuid
  
  employee        Employee @relation(fields: [employeeId], references: [id])
  salary          Salary   @relation(fields: [salaryId], references: [id])

  month           Int
  year            Int

  data            Json

  createdAt       DateTime @default(now())

  @@map("payslips")
}
