generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYER
  ADMIN
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.VarChar(50)
  password  String   @db.VarChar(200)
  name      String   @db.VarChar(200)
  role      Role     @default(EMPLOYER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Company {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(200)
  email     String?    @db.VarChar(200)
  phone     String?    @db.VarChar(30)
  address   String?    @db.Text
  logoUrl   String?    @db.Text

  employers Employer[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("companies")
}

model Employer {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(200)
  address   String?    @db.Text
  phone     String?    @db.VarChar(30)

  companyId String     @db.Uuid
  company   Company    @relation(fields: [companyId], references: [id])

  employees Employee[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([companyId])
  @@map("employers")
}

model Department {
  id         String     @id @default(uuid()) @db.Uuid
  name       String     @unique @db.VarChar(100)
  is_deleted Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  employees  Employee[]

  @@index([name])
  @@map("departments")
}

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  firstName       String    @db.VarChar(100)
  lastName        String    @db.VarChar(100)
  phone           String    @db.VarChar(20)
  address         String?   @db.Text
  dateOfBirth     DateTime?
  gender          String?   @db.VarChar(20)
  qualification   String?   @db.VarChar(100)
  salary          Float
  previousSalary  Float?
  permittedLeaves Int?
  is_deleted      Boolean   @default(false)

  departmentId    String    @db.Uuid
  department      Department @relation(fields: [departmentId], references: [id])

  employerId      String?   @db.Uuid
  employer        Employer?  @relation(fields: [employerId], references: [id], onDelete: SetNull)

  salaries        Salary[]
  payslips        Payslip[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([departmentId])
  @@index([employerId])
  @@map("employees")
}

model Salary {
  id              String   @id @default(uuid()) @db.Uuid
  
  employeeId      String   @db.Uuid
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month           Int
  year            Int

  workingDays     Int
  workingHours    Int

  basicSalary     Float
  incentive       Float?
  bonus           Float?
  taDa            Float?
  arrears         Float?

  otHours         Float?
  otPay           Float?

  leavesTaken     Int?
  leavePenalty    Float?

  minusMinutes    Int?
  timePenalty     Float?

  extraFine       Float?

  professionalTax Float?
  emi             Float?

  advanceTaken    Float?
  advanceDeducted Float?

  grossSalary     Float
  totalDeduction  Float
  netSalary       Float

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payslip         Payslip?

  @@unique([employeeId, month, year])
  @@map("salaries")
}

model Payslip {
  id              String   @id @default(uuid()) @db.Uuid
  
  employeeId      String   @db.Uuid
  salaryId        String   @unique @db.Uuid
  
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salary          Salary   @relation(fields: [salaryId], references: [id])

  month           Int
  year            Int

  data            Json

  createdAt       DateTime @default(now())

  @@map("payslips")
}
